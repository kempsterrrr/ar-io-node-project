# Server
PORT=4001
NODE_ENV=development
LOG_LEVEL=debug

# Gateway connection
# Local dev: http://localhost:3000
# Docker: http://envoy:3000 (must go through Envoy for peer-proxied data)
GATEWAY_URL=http://localhost:3000

# Gateway request timeout (ms)
GATEWAY_TIMEOUT_MS=10000

# SQLite database path
SQLITE_PATH=./data/verify.db

# PDF signing key (Phase 2)
# SERVICE_SIGNING_KEY_PATH=./keys/verify-service.key
# SERVICE_SIGNING_CERT_PATH=./keys/verify-service.crt

# Multi-gateway consensus (Phase 3)
# MULTI_GATEWAY_ENABLED=false
# MULTI_GATEWAY_COUNT=5
# MULTI_GATEWAY_TIMEOUT_MS=10000
# MULTI_GATEWAY_MIN_CONSENSUS=3

# On-demand indexing (Phase 2)
# GATEWAY_ADMIN_API_KEY=
# ON_DEMAND_INDEX_ENABLED=false
# ON_DEMAND_INDEX_TIMEOUT_MS=60000

# Turbo integration for archiving (Phase 3)
# TURBO_PRIVATE_KEY=
# TURBO_TOKEN=arweave
