# =============================================================================
# Turbo C2PA SDK Configuration
# =============================================================================

# Ethereum wallet private key (for Turbo SDK uploads to Arweave)
# Must have Turbo credits: https://turbo.ardrive.io
ETH_PRIVATE_KEY=0x...

# C2PA sidecar URL (signing oracle + SBR API)
SIDECAR_URL=http://localhost:3003

# Gateway URL for viewing uploaded content
# Testing: https://turbo-gateway.com (instant availability)
# Production: your gateway URL running the sidecar (e.g. https://ario.agenticway.io)
GATEWAY_URL=https://turbo-gateway.com

# SBR API base URL (for manifest discovery)
MANIFEST_REPO_URL=http://localhost:3003/v1

# Dev trust anchor CA certificate (base64-encoded PEM)
# Generate with: cd ../trusthash-sidecar && ./scripts/generate-dev-cert.sh
# Copy the C2PA_TRUST_ANCHOR_PEM value from the output
C2PA_TRUST_ANCHOR_PEM=
