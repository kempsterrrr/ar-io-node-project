{
  "name": "@kempsterrrr/openclaw-ario-plugin",
  "version": "0.2.0",
  "description": "OpenClaw plugin for AR.IO gateways and Arweave, powered by @agenticway/sdk",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kempsterrrr/ar-io-node-project.git",
    "directory": "packages/openclaw-ario-plugin"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@agenticway/sdk": "workspace:*",
    "openclaw": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@agenticway/sdk": "workspace:*",
    "@types/node": "^25.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "arweave",
    "ar-io",
    "gateway",
    "agenticway"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
