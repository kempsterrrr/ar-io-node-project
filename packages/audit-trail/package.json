{
  "name": "@agenticway/audit-trail",
  "version": "0.1.0",
  "description": "Tamper-evident activity logging for AI agents with Arweave-anchored Merkle integrity proofs",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agenticway/sdk": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "agenticway",
    "audit-trail",
    "ai-agents",
    "merkle-tree",
    "arweave",
    "tamper-evident",
    "logging"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ar-io/ar-io-node-project",
    "directory": "packages/audit-trail"
  }
}
