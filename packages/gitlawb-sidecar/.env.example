# =============================================================================
# Gitlawb Sidecar — operator configuration
# =============================================================================
# Copy this file to `.env` (or let `make init` generate it for you).
# `.env` is gitignored. Keep your private key out of version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Required: public-facing URL
# -----------------------------------------------------------------------------
# Where peers will reach your node over HTTPS. Typically an ArNS subdomain
# routed by your gateway's Envoy to gitlawb-node:7545.
# Example: https://git.yourgateway.example
GITLAWB_PUBLIC_URL=

# -----------------------------------------------------------------------------
# Required: Postgres credentials (internal to compose project)
# -----------------------------------------------------------------------------
# `make init` generates a random POSTGRES_PASSWORD for you. DATABASE_URL is
# composed from these values inside docker-compose.yaml, so there's a single
# source of truth.
POSTGRES_USER=gitlawb
POSTGRES_DB=gitlawb
POSTGRES_PASSWORD=

# -----------------------------------------------------------------------------
# Required for on-chain staking + rewards (Base L2)
# -----------------------------------------------------------------------------
# Base L2 RPC endpoint. Public option: https://mainnet.base.org
# Recommended: your own provider (Alchemy, Infura, QuickNode, etc.)
GITLAWB_CHAIN_RPC_URL=

# Operator wallet for staking and heartbeat transactions on Base.
# WARNING: This wallet signs gas-paying transactions.
#   - Fund with ~0.005 ETH on Base for ongoing gas
#   - Transfer >=10,000 $GITLAWB into this wallet before `make stake`
#   - DO NOT reuse a high-value wallet — generate a dedicated operator key
GITLAWB_OPERATOR_PRIVATE_KEY=

# NodeStaking contract address on Base. See upstream docs for the canonical
# deployment. Required when GITLAWB_OPERATOR_PRIVATE_KEY is set.
GITLAWB_CONTRACT_NODE_STAKING=

# Optional: $GITLAWB token contract address (defaults to upstream constant).
# GITLAWB_TOKEN=

# Optional: refuse to start if node is not registered or not currently active.
# Recommended after first `make stake` succeeds.
GITLAWB_OPERATOR_STRICT_MODE=false

# Optional: heartbeat interval in hours. Must be < 24. Default 20.
# GITLAWB_HEARTBEAT_INTERVAL_HOURS=20

# -----------------------------------------------------------------------------
# Optional: IPFS pinning (Pinata)
# -----------------------------------------------------------------------------
# When set, pushed git objects are pinned to Pinata and the CID is embedded
# in the Arweave anchor. Recommended if you want your repos to be reachable
# by AR.IO-side indexers and other mirrors.
# Sign up: https://pinata.cloud — create a JWT with pin/upload scope.
GITLAWB_PINATA_JWT=

# Optional: local IPFS daemon (Kubo) HTTP API. Pinned in parallel with Pinata.
# Example: http://host.docker.internal:5001
# GITLAWB_IPFS_API=

# -----------------------------------------------------------------------------
# Optional: Arweave anchoring via Irys
# -----------------------------------------------------------------------------
# When set, each ref-update is anchored on Arweave with tags:
#   App-Name=gitlawb, Schema=gitlawb/ref-update/v1, Repo, Ref, SHA, Node-DID
# v0.1 uses Irys directly. A future release (v0.3) will provide an AR.IO-native
# bridge so your gateway's bundler handles anchoring.
# GITLAWB_IRYS_URL=https://node1.irys.xyz

# -----------------------------------------------------------------------------
# Image / version pinning (advanced)
# -----------------------------------------------------------------------------
# The image used by both gitlawb-node and the gl ops service.
GITLAWB_SIDECAR_IMAGE=ghcr.io/kempsterrrr/gitlawb-sidecar:latest

# Postgres version. Match upstream's docker-compose.yml.
GITLAWB_POSTGRES_IMAGE=postgres:16-alpine
