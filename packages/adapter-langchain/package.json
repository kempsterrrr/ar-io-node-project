{
  "name": "@agenticway/adapter-langchain",
  "version": "0.1.0",
  "description": "LangChain adapter for @agenticway/sdk — AI agent tools for permanent data storage on Arweave",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@agenticway/sdk": "workspace:*",
    "@langchain/core": ">=0.2.0",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "@agenticway/sdk": "workspace:*",
    "@langchain/core": "^0.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.0.0",
    "zod": "^3.23.0"
  },
  "keywords": [
    "agenticway",
    "langchain",
    "arweave",
    "tools",
    "agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kempsterrrr/ar-io-node-project",
    "directory": "packages/adapter-langchain"
  }
}
