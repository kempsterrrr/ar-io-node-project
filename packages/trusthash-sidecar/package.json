{
  "name": "@ar-io/trusthash-sidecar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "build": "tsup src/index.ts src/migrate.ts --format esm --platform node",
    "start": "node dist/index.js",
    "migrate": "node dist/migrate.js",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "dependencies": {
    "@ar-io/c2pa-protocol": "workspace:*",
    "@hono/node-server": "^1.16.0",
    "ethers": "^6.13.0",
    "@iscc/lib": "^0.3.1",
    "blockhash-core": "^0.1.0",
    "duckdb-async": "^1.1.0",
    "hono": "^4.6.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "sharp": "^0.33.0",
    "undici": "^6.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.0.0"
  }
}
