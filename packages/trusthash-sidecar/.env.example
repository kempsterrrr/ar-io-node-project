# =============================================================================
# Trusthash Sidecar Configuration
# =============================================================================

# Server
PORT=3003
NODE_ENV=development
LOG_LEVEL=debug

# Docker Proxy (only used with docker-compose)
# External port for nginx proxy (default: 3003)
PROXY_PORT=3003

# DuckDB Database
# Path to the persistent DuckDB database file
DUCKDB_PATH=./data/provenance.duckdb

# Gateway Connection
# Internal gateway URL (use core:4000 when running in Docker)
GATEWAY_URL=http://localhost:3000

# Image Processing
# Maximum image size in MB (default: 50)
MAX_IMAGE_SIZE_MB=50

# Reference Fetch
# Timeout in milliseconds when fetching reference URLs (default: 10000)
REFERENCE_FETCH_TIMEOUT_MS=10000

# Remote manifest fetch-through cache (proof-locator artifact mode)
REMOTE_MANIFEST_CACHE_TTL_MS=300000
REMOTE_MANIFEST_CACHE_MAX_ENTRIES=200
REMOTE_MANIFEST_MAX_BYTES=26214400

# Feature flags
ENABLE_PROOF_LOCATOR_ARTIFACTS=true
ENABLE_BY_REFERENCE=true

# =============================================================================
# Signing Oracle (COSE signing for C2PA)
# =============================================================================
# Enable the signing oracle (POST /v1/sign, GET /v1/cert)
ENABLE_SIGNING=false

# Signing algorithm (ES256 = P-256/SHA-256, ES384 = P-384/SHA-384)
SIGNING_ALGORITHM=ES256

# Certificate chain (PEM format, base64-encoded for env var storage)
# Generate dev certs: ./scripts/generate-dev-cert.sh
# SIGNING_CERT_PEM=<base64-encoded PEM certificate chain>

# Private key for development (PEM format, base64-encoded)
# For production, use KMS_KEY_ARN instead
# SIGNING_PRIVATE_KEY_PEM=<base64-encoded PEM private key>

# AWS KMS for production signing (future)
# KMS_KEY_ARN=arn:aws:kms:us-east-1:123456789:key/abc-def
# KMS_REGION=us-east-1
