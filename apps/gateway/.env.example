# =============================================================================
# AR.IO Gateway Configuration
# =============================================================================
# Copy this file to .env and fill in the required values
# For full documentation, see: https://docs.ar.io/build/run-a-gateway/quick-start
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED CONFIGURATION
# -----------------------------------------------------------------------------

# Your Arweave wallet address (operator wallet)
AR_IO_WALLET=

# Observer wallet address (hot wallet for submitting reports)
OBSERVER_WALLET=

# Your domain name (e.g., gateway.example.com)
# Leave empty for local development
ARNS_ROOT_HOST=

# -----------------------------------------------------------------------------
# IMAGE VERSIONS
# -----------------------------------------------------------------------------

# Pin gateway images to a specific version for debugging.
# By default, `pnpm run dev` pulls the latest images automatically.
# Override to test against a specific release:
#   CORE_IMAGE_TAG=release-20 pnpm run dev
# CORE_IMAGE_TAG=latest
# ENVOY_IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# NETWORK CONFIGURATION
# -----------------------------------------------------------------------------

# GraphQL endpoint for Arweave data
GRAPHQL_HOST=arweave.net
GRAPHQL_PORT=443

# Starting block height for indexing
# Use a high number (e.g., 1400000) for faster initial sync
# Use 0 for full historical data (requires significant storage)
START_HEIGHT=1400000

# -----------------------------------------------------------------------------
# OBSERVER CONFIGURATION
# -----------------------------------------------------------------------------

# Enable the observer for network participation
RUN_OBSERVER=false

# How to pay for observer report uploads
# Options: turbo (default, uses Turbo Credits), arweave (uses AR tokens)
# REPORT_DATA_SINK=turbo

# -----------------------------------------------------------------------------
# OPTIONAL FEATURES
# -----------------------------------------------------------------------------

# Enable admin API (for debugging/monitoring, also required for bundler optical bridging)
# ADMIN_API_KEY=

# Enable GraphQL API
# ENABLE_GRAPHQL=true

# Trusted node URL for data fetching
# TRUSTED_NODE_URL=https://arweave.net

# Chunk data sources (comma-separated)
# CHUNK_DATA_SOURCE=arweave-net

# -----------------------------------------------------------------------------
# C2PA / TRUSTHASH SIDECAR INTEGRATION
# -----------------------------------------------------------------------------

# Send webhooks to the trusthash sidecar when C2PA transactions are indexed
# WEBHOOK_TARGET_SERVERS=http://trusthash-sidecar:3003/webhook

# Filter for which transactions trigger webhooks (C2PA-Manifest-Proof protocol)
# WEBHOOK_INDEX_FILTER={"tags":[{"name":"Protocol","value":"C2PA-Manifest-Proof"}]}

# Index C2PA transactions for GraphQL queries
# ANS104_INDEX_FILTER={"tags":[{"name":"Protocol","value":"C2PA-Manifest-Proof"}]}

# Unbundle ANS-104 bundles containing C2PA data items
# ANS104_UNBUNDLE_FILTER={"tags":[{"name":"Protocol","value":"C2PA-Manifest-Proof"}]}

# -----------------------------------------------------------------------------
# DATA AVAILABILITY (multi-gateway fan-out)
# -----------------------------------------------------------------------------

# Trusted gateways for on-demand data retrieval (JSON: url -> weight)
# Higher weight = tried first. Required for secondary gateways to fetch
# data from the primary gateway where Turbo cached it.
# TRUSTED_GATEWAYS_URLS={"https://turbo-gateway.com": 2, "https://arweave.net": 1}

# Timeout for trusted gateway requests (ms). Lower = faster fallback.
# TRUSTED_GATEWAYS_REQUEST_TIMEOUT_MS=5000

# Priority order for fetching data on request.
# Put trusted-gateways first when data is uploaded via Turbo.
# ON_DEMAND_RETRIEVAL_ORDER=trusted-gateways,chunks,tx-data

# -----------------------------------------------------------------------------
# PERFORMANCE TUNING
# -----------------------------------------------------------------------------

# Number of workers for L1 bundle unbundling
# ANS104_UNBUNDLE_WORKERS=1

# Concurrent download threads for on-demand data retrieval from trusted gateways.
# Increase if retrieval is slow due to download workers being busy with L1 sync.
# Default: 5. Production recommendation: 10.
# ANS104_DOWNLOAD_WORKERS=10

# Maximum concurrent chunk downloads
# MAX_CHUNK_CONCURRENT_REQUESTS=100
