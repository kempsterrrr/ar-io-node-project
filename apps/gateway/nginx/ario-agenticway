# ario.agenticway.io → AR.IO Gateway
# Managed by: .github/workflows/deploy-gateway.yml
server {
    listen 80;
    server_name ario.agenticway.io *.ario.agenticway.io;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name ario.agenticway.io *.ario.agenticway.io;

    ssl_certificate /etc/letsencrypt/live/ario.agenticway.io/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/ario.agenticway.io/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    # Verify sidecar — all /verify/ traffic proxied to sidecar on port 4001
    # Trailing slash on proxy_pass strips the /verify prefix
    location /verify/ {
        proxy_pass http://localhost:4001/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        client_max_body_size 50M;
    }

    # Trusthash sidecar health (at root, not under /v1)
    location = /trusthash/health {
        proxy_pass http://localhost:3003/health;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Trusthash sidecar — C2PA manifest repository & SBR API on port 3003
    # Trailing slash on proxy_pass rewrites /trusthash/* → /v1/*
    location /trusthash/ {
        proxy_pass http://localhost:3003/v1/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        client_max_body_size 50M;
    }

    # Gateway (default — must be last)
    location / {
        proxy_pass http://localhost:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
