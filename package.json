{
  "name": "ar-io-node-project",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "agentic:validate": "node scripts/agentic-validate.mjs --mode=validate",
    "agentic:check-drift": "node scripts/agentic-validate.mjs --mode=drift",
    "clean": "turbo run clean && rm -rf node_modules",
    "test:production": "node scripts/test-production.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.1.0",
    "tsx": "^4.0.0",
    "turbo": "^2.3.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@9.15.0"
}
