{
  "name": "ar-io-node-project",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "node_modules/turbo/bin/turbo run build",
    "dev": "node_modules/turbo/bin/turbo run dev",
    "lint": "node_modules/turbo/bin/turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "agentic:validate": "node scripts/agentic-validate.mjs --mode=validate",
    "agentic:check-drift": "node scripts/agentic-validate.mjs --mode=drift",
    "clean": "node_modules/turbo/bin/turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^25.0.1",
    "prettier": "^3.1.0",
    "turbo": "^2.3.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "bun@1.2.23",
  "trustedDependencies": [
    "@contentauth/c2pa-node",
    "better-sqlite3",
    "duckdb"
  ]
}
